VANTRIGON_APP_NAME="Vantrigon Tech API"
VANTRIGON_APP_ENV=development
VANTRIGON_DEBUG=true
VANTRIGON_API_PREFIX=/api

# Use SQLite locally. For PostgreSQL, use:
# VANTRIGON_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/vantrigon
VANTRIGON_DATABASE_URL=sqlite:///./vantrigon.db

# Comma-separated frontend origins allowed by CORS.
VANTRIGON_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Optional SMTP settings for contact notifications.
VANTRIGON_EMAIL_ENABLED=false
VANTRIGON_SMTP_HOST=smtp.example.com
VANTRIGON_SMTP_PORT=587
VANTRIGON_SMTP_USERNAME=
VANTRIGON_SMTP_PASSWORD=
VANTRIGON_SMTP_FROM=hello@vantrigon.com
VANTRIGON_CONTACT_NOTIFICATION_TO=hello@vantrigon.com
